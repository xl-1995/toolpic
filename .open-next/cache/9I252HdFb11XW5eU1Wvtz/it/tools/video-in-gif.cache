ine | ToolPic\"}],[\"$\",\"meta\",\"37\",{\"name\":\"twitter:description\",\"content\":\"Converti video in GIF online gratis. Personalizza frame rate, dimensione e durata. Nessun software necessario.\"}],[\"$\",\"meta\",\"38\",{\"name\":\"twitter:image\",\"content\":\"https://toolpic.me/og-image.jpg\"}],[\"$\",\"link\",\"39\",{\"rel\":\"icon\",\"href\":\"/favicon.svg\",\"type\":\"image/svg+xml\"}],[\"$\",\"link\",\"40\",{\"rel\":\"icon\",\"href\":\"/icon-512.png\",\"type\":\"image/png\",\"sizes\":\"512x512\"}],[\"$\",\"link\",\"41\",{\"rel\":\"apple-touch-icon\",\"href\":\"/apple-touch-icon.png\"}],[\"$\",\"$L21\",\"42\",{}]],\"error\":null,\"digest\":\"$undefined\"}\ne:\"$9:metadata\"\n"}