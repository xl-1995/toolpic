muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"Compressore video\\\"}]\\n1f:[\\\"$\\\",\\\"$L20\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/it/tools/video-to-gif\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":\\\"$1c:props:localeCookie\\\",\\\"className\\\":\\\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"Video in GIF\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"b:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initial-scale=1\\\"}]]\\n7:null\\n\"])</script><script>self.__next_f.push([1,\"21:I[622,[],\\\"IconMark\\\"]\\n\"])</script><script>self.__next_f.push([1,\"9:{\\\"metadata\\\":[[\\\"$\\\",\\\"title\\\",\\\"0\\\",{\\\"children\\\":\\\"Convertitore video in GIF gratuito online | ToolPic\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"Converti video in GIF online gratis. Personalizza frame rate, dimensione e durata. Nessun software necessario.\\\"}],[\\\"$\\\",\\\"link\\\",\\\"2\\\",{\\\"rel\\\":\\\"manifest\\\",\\\"href\\\":\\\"/manifest.json\\\",\\\"crossOrigin\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"link\\\",\\\"3\\\",{\\\"rel\\\":\\\"canonical\\\",\\\"href\\\":\\\"https://toolpic.me/it/tools/video-in-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"4\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"en\\\",\\\"href\\\":\\\"https://toolpic.me/en/tools/video-to-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"5\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"zh\\\",\\\"href\\\":\\\"https://toolpic.me/zh/tools/video-to-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"6\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"ja\\\",\\\"href\\\":\\\"https://toolpic.me/ja/tools/video-to-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"7\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"ko\\\",\\\"href\\\":\\\"https://toolpic.me/ko/tools/video-to-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"8\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"es\\\",\\\"href\\\":\\\"https://toolpic.me/es/tools/video-a-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"9\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"fr\\\",\\\"href\\\":\\\"https://toolpic.me/fr/tools/video-en-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"10\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"de\\\",\\\"href\\\":\\\"https://toolpic.me/de/tools/video-zu-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"11\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"pt\\\",\\\"href\\\":\\\"https://toolpic.me/pt/tools/video-para-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"12\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"ru\\\",\\\"href\\\":\\\"https://toolpic.me/ru/tools/video-v-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"13\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"ar\\\",\\\"href\\\":\\\"https://toolpic.me/ar/tools/video-to-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"14\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"hi\\\",\\\"href\\\":\\\"https://toolpic.me/hi/tools/video-to-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"15\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"it\\\",\\\"href\\\":\\\"https://toolpic.me/it/tools/video-in-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"16\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"tr\\\",\\\"href\\\":\\\"https://toolpic.me/tr/tools/video-gif-donusturucu\\\"}],[\\\"$\\\",\\\"link\\\",\\\"17\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"vi\\\",\\\"href\\\":\\\"https://toolpic.me/vi/tools/video-sang-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"18\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"th\\\",\\\"href\\\":\\\"https://toolpic.me/th/tools/video-to-gif\\\"}],[\\\"$\\\",\\\"link\\\",\\\"19\\\",{\\\"rel\\\":\\\"alternate\\\",\\\"hrefLang\\\":\\\"id\\\",\\\"href\\\":\\\"https://toolpic.me/id/tools/video-ke-gif\\\"}],[\\\