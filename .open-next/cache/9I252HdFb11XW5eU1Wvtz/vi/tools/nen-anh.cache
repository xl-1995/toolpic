content\":\"website\"}],[\"$\",\"meta\",\"35\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"36\",{\"name\":\"twitter:title\",\"content\":\"Nen hinh anh mien phi - Giam kich thuoc anh truc tuyen | ToolPic\"}],[\"$\",\"meta\",\"37\",{\"name\":\"twitter:description\",\"content\":\"Nen anh JPEG, PNG, WebP, AVIF truc tuyen mien phi. Giam kich thuoc tep len den 80% voi nen thong minh. Khong tai len, 100% trong trinh duyet.\"}],[\"$\",\"meta\",\"38\",{\"name\":\"twitter:image\",\"content\":\"https://toolpic.me/og-image.jpg\"}],\"$L1c\",\"$L1d\",\"$L1e\",\"$L1f\"],\"error\":null,\"digest\":\"$undefined\"}\n20:I[622,[],\"IconMark\"]\n1c:[\"$\",\"link\",\"39\",{\"rel\":\"icon\",\"href\":\"/favicon.svg\",\"type\":\"image/svg+xml\"}]\n1d:[\"$\",\"link\",\"40\",{\"rel\":\"icon\",\"href\":\"/icon-512.png\",\"type\":\"image/png\",\"sizes\":\"512x512\"}]\n1e:[\"$\",\"link\",\"41\",{\"rel\":\"apple-touch-icon\",\"href\":\"/apple-touch-icon.png\"}]\n1f:[\"$\",\"$L20\",\"42\",{}]\ne:\"$9:metadata\"\n"}