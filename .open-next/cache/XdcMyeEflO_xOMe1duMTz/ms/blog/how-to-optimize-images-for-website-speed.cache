\",\"children\":[\"$\",\"li\",null,{\"children\":\"$L44\"}]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-lg font-semibold mb-4\",\"children\":\"Undang-undang\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"span\",null,{\"className\":\"cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Dasar Privasi\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"span\",null,{\"className\":\"cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Terma Perkhidmatan\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"span\",null,{\"className\":\"cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Hubungi\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"pt-8 border-t border-[var(--color-border)] text-center text-sm text-[var(--color-text-dim)]\",\"children\":\"© 2026 ToolPic. Hak cipta terpelihara.\"}]]}]}]\n3c:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/image-compressor\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Pemampat Imej\"}]\n3d:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/image-converter\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Penukar Imej\"}]\n3e:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/image-crop\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Potong & Ubah Saiz Imej\"}]\n3f:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/image-watermark\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Tambah Tera Air\"}]\n40:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/image-bg-remove\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Buang Latar Belakang\"}]\n41:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/video-compress\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Pemampat Video\"}]\n42:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/video-convert\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Penukar Video\"}]\n43:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/tools/video-to-gif\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Video ke GIF\"}]\n44:[\"$\",\"$L23\",null,{\"ref\":\"$undefined\",\"href\":\"/ms/blog\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"Blog\"}]\n18:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n14:null\n16:{\"metadata\":[[\"$\",\"t