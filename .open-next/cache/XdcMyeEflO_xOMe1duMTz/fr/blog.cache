i\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"Contact\\\"}]}]]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"pt-8 border-t border-[var(--color-border)] text-center text-sm text-[var(--color-text-dim)]\\\",\\\"children\\\":\\\"© 2026 ToolPic. Tous droits reserves.\\\"}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"4e:[\\\"$\\\",\\\"$L31\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/fr/tools/image-compressor\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":\\\"$1c:props:localeCookie\\\",\\\"className\\\":\\\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"Compresseur d'images\\\"}]\\n4f:[\\\"$\\\",\\\"$L31\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/fr/tools/image-converter\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":\\\"$1c:props:localeCookie\\\",\\\"className\\\":\\\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"Convertisseur d'images\\\"}]\\n50:[\\\"$\\\",\\\"$L31\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/fr/tools/image-crop\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":\\\"$1c:props:localeCookie\\\",\\\"className\\\":\\\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"Recadrer et redimensionner\\\"}]\\n51:[\\\"$\\\",\\\"$L31\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/fr/tools/image-watermark\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":\\\"$1c:props:localeCookie\\\",\\\"className\\\":\\\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"Ajouter un filigrane\\\"}]\\n52:[\\\"$\\\",\\\"$L31\\\",nu