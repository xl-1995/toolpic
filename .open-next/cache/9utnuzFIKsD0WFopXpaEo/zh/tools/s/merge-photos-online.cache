className\\\":\\\"text-lg font-semibold mb-4\\\",\\\"children\\\":\\\"法律\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"隐私政策\\\"}]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"服务条款\\\"}]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"联系我们\\\"}]}]]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"pt-8 border-t border-[var(--color-border)] text-center text-sm text-[var(--color-text-dim)]\\\",\\\"children\\\":\\\"© 2026 ToolPic. 保留所有权利。\\\"}]]}]}]\\n\"])</script><script>self.__next_f.push([1,\"1b:I[7088,[\\\"707\\\",\\\"static/chunks/707-a8cb8823e74114e8.js\\\",\\\"287\\\",\\\"static/chunks/287-f0778ca6bf51fa86.js\\\",\\\"145\\\",\\\"static/chunks/app/%5Blocale%5D/tools/s/%5Bslug%5D/page-62cbbf95a2da758e.js\\\"],\\\"default\\\"]\\n17:[\\\"$\\\",\\\"$L1b\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/zh/tools/image-compressor\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":{\\\"name\\\":\\\"NEXT_LOCALE\\\",\\\"sameSite\\\":\\\"lax\\\"},\\\"className\\\":\\\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\\\",\\\"children\\\":\\\"图片压缩\\\"}]\\n18:[\\\"$\\\",\\\"$L1b\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/zh/tools/image-converter\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":\\\"$17:props:localeCookie\\\",\\\"className\\\":\\\"text-[