\\"$\\\",\\\"img\\\",null,{\\\"src\\\":\\\"/blog/ecommerce-images-hero.jpg\\\",\\\"alt\\\":\\\"E-Commerce Produktbild-Optimierung: Kompletter Leitfaden\\\",\\\"className\\\":\\\"w-full h-auto\\\"}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"section\\\",\\\"0\\\",{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\\\",\\\"children\\\":\\\"Warum Produktbilder den Umsatz antreiben\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\\\",\\\"children\\\":\\\"Im E-Commerce sind Produktbilder Ihr stärkstes Verkaufswerkzeug. 75 % der Online-Käufer verlassen sich bei Kaufentscheidungen auf Produktfotos.\\\"}]]}],[\\\"$\\\",\\\"section\\\",\\\"1\\\",{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\\\",\\\"children\\\":\\\"Empfohlene Größen und Formate\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\\\",\\\"children\\\":\\\"Für Hauptproduktbilder verwenden Sie 1000 bis 2000 Pixel an der längsten Seite. Die meisten Plattformen empfehlen 1200 x 1200 oder 1500 x 1500 Pixel.\\\"}]]}],[\\\"$\\\",\\\"section\\\",\\\"2\\\",{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\\\",\\\"children\\\":\\\"Bild-SEO für E-Commerce\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\\\",\\\"children\\\":\\\"Suchmaschinen können Ihre Bilder nicht sehen, aber sie lesen den zugehörigen Text. Beschreibende Dateinamen sind wichtig.\\\"}]]}],[\\\"$\\\",\\\"section\\\",\\\"3\\\",{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\\\",\\\"children\\\":\\\"Produktbilder mit ToolPic optimieren\\\"}],\\\"$L1e\\\"]}]]}],\\\"$L1f\\\"]}]]\\n\"])</script><script>self.__next_f.push([1,\"1e:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\\\",\\\"children\\\":\\\"Beginnen Sie damit, Ihre Produktfotos mit dem Bildzuschnitt-Tool auf ein einheitliches Seitenverhältnis zuzuschneiden. Quadratische Zuschnitte (1:1) funktionieren am besten.\\\"}]\\n1f:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-16 pt-10 border-t border-[var(--color-border)]\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-xl font-bold mb-6 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"fas fa-wrench text-[var(--color-purple)]\\\"}],\\\"Verwandte Tools\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid grid-cols-1 sm:grid-cols-2 gap-4\\\",\\\"children\\\":[\\\"$L20\\\",\\\"$L21\\\"]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"22:I[7088,[\\\"619\\\",\\\"static/chunks/619-ba102abea3e3d0e4.js\\\",\\\"707\\\",\\\"static/chunks/707-58f78ad8b0d495a8.js\\\",\\\"414\\\",\\\"static/chunks/app/%5Blocale%5D/blog/%5Bslug%5D/page-2e29ca0deafe7a99.js\\\"],\\\"default\\\"]\\n1d:[\\\"$\\\",\\\"$L22\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/de/blog\\\",\\\"locale\\\":\\\"$undefined\\\",\\\"localeCookie\\\":{\\\"name\\\":\\\"NEXT_LOCALE\\\",\\\"sameSite\\\":\\\"lax\\\"},\\\"className\\\":\\\"inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300 mb-8\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"fas fa-arrow-left text-xs\\\"}],\\\"Blog\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"20:[\\\"$\\\",\\\"$L22\\\",\\\"image-compressor\\\",{\\\"ref\\\":\\\"$undefined\\\",\\\"href\\\":\\\"/de/tools/bild-kompri