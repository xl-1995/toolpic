26\\\",{\\\"property\\\":\\\"og:description\\\",\\\"content\\\":\\\"Corte e redimensione imagens online gratis. Dimensoes predefinidas para redes sociais. Sem necessidade de upload.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"27\\\",{\\\"property\\\":\\\"og:url\\\",\\\"content\\\":\\\"https://toolpic.me/pt/tools/cortar-imagem\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"28\\\",{\\\"property\\\":\\\"og:site_name\\\",\\\"content\\\":\\\"ToolPic\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"29\\\",{\\\"property\\\":\\\"og:locale\\\",\\\"content\\\":\\\"pt\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"30\\\",{\\\"property\\\":\\\"og:image\\\",\\\"content\\\":\\\"https://toolpic.me/og-image.jpg\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"31\\\",{\\\"property\\\":\\\"og:image:width\\\",\\\"content\\\":\\\"1200\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"32\\\",{\\\"property\\\":\\\"og:image:height\\\",\\\"content\\\":\\\"630\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"33\\\",{\\\"property\\\":\\\"og:image:alt\\\",\\\"content\\\":\\\"ToolPic - Free Online Image \\u0026 Video Tools\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"34\\\",{\\\"property\\\":\\\"og:type\\\",\\\"content\\\":\\\"website\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"35\\\",{\\\"name\\\":\\\"twitter:card\\\",\\\"content\\\":\\\"summary_large_image\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"36\\\",{\\\"name\\\":\\\"twitter:title\\\",\\\"content\\\":\\\"Ferramenta gratis de corte e redimensionamento de imagens | ToolPic\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"37\\\",{\\\"name\\\":\\\"twitter:description\\\",\\\"content\\\":\\\"Corte e redimensione imagens online gratis. Dimensoes predefinidas para redes sociais. Sem necessidade de upload.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"38\\\",{\\\"name\\\":\\\"twitter:image\\\",\\\"content\\\":\\\"https://toolpic.me/og-image.jpg\\\"}],[\\\"$\\\",\\\"link\\\",\\\"39\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/favicon.svg\\\",\\\"type\\\":\\\"image/svg+xml\\\"}],[\\\"$\\\",\\\"link\\\",\\\"40\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/icon-512.png\\\",\\\"type\\\":\\\"ima