{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/tools/layout,_N_T_/[locale]/tools/[slug]/layout,_N_T_/[locale]/tools/[slug]/page,_N_T_/ru/tools/video-v-gif"}},"html":"<!DOCTYPE html><!--ie9Rn32mHKdwf9dJfsX_H--><html lang=\"ru\" dir=\"ltr\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/33d53a709b95525f.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-5f7aa716bc7d8d39.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-ebd51be49873d76c.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-9fa8c0a1addc7277.js\" async=\"\"></script><script src=\"/_next/static/chunks/619-ba102abea3e3d0e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/not-found-a264dd7cd5226d7f.js\" async=\"\"></script><script src=\"/_next/static/chunks/707-58f78ad8b0d495a8.js\" async=\"\"></script><script src=\"/_next/static/chunks/287-f0778ca6bf51fa86.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/%5Blocale%5D/tools/%5Bslug%5D/page-9e48818c6b22c238.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/%5Blocale%5D/page-166517544bc7e5ba.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/%5Blocale%5D/layout-bbd3d848790208e9.js\" async=\"\"></script><link rel=\"manifest\" href=\"/manifest.json\"/><meta name=\"theme-color\" content=\"#7c3aed\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\"/><title>Бесплатный конвертер видео в GIF онлайн | ToolPic</title><meta name=\"description\" content=\"Конвертируйте видео в GIF онлайн бесплатно. Настройте частоту кадров, размер и длительнос