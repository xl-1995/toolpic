]}],[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}],{\"children\":[[\"locale\",\"pl\",\"d\"],\"$Lb\",{\"children\":[\"tools\",\"$Lc\",{\"children\":[\"s\",\"$Ld\",{\"children\":[[\"slug\",\"resize-image-for-instagram\",\"d\"],\"$Le\",{\"children\":[\"__PAGE__\",\"$Lf\",{},null,false]},null,false]},null,false]},null,false]},null,false]},null,false],\"$L10\",false]],\"m\":\"$undefined\",\"G\":[\"$11\",[]],\"s\":false,\"S\":true}\n14:I[4431,[],\"OutletBoundary\"]\n16:I[5278,[],\"AsyncMetadataOutlet\"]\n18:I[4431,[],\"ViewportBoundary\"]\n1a:I[4431,[],\"MetadataBoundary\"]\n1b:\"$Sreact.suspense\"\n5:[\"$\",\"i\",null,{\"className\":\"fas fa-exchange-alt\",\"style\":{\"fontSize\":\"1rem\"}}]\n6:[\"$\",\"div\",null,{\"style\":{\"fontWeight\":600,\"marginBottom\":\"0.25rem\"},\"children\":\"Image Converter\"}]\n7:[\"$\",\"$L4\",\"image-crop\",{\"href\":\"/en/tools/image-crop\",\"style\":{\"display\":\"block\",\"padding\":\"1.25rem\",\"backgroundColor\":\"rgba(255, 255, 255, 0.03)\",\"border\":\"1px solid rgba(255, 255, 255, 0.06)\",\"borderRadius\":\"1.25rem\",\"textDecoration\":\"none\",\"color\":\"#f4f4f5\",\"transition\":\"transform 0.3s, background-color 0.3s\"},\"children\":[[\"$\",\"div\",null,{\"style\":{\"width\":\"2.5rem\",\"height\":\"2.5rem\",\"borderRadius\":\"50%\",\"background\":\"linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(59, 130, 246, 0.1))\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"center\",\"marginBottom\":\"0.75rem\"},\"children\":[\"$\",\"i\",null,{\"className\":\"fas fa-crop\",\"style\":{\"fontSize\":\"1rem\"}}]}],[\"$\",\"div\",null,{\"style\":{\"fontWeight\":600,\"marginBottom\":\"0.25rem\"},\"children\":\"Image Crop\"}]]}]\n8:[\"$\",\"$L4\",\"image-watermark\",{\"href\":\"/en/tools/image-watermark\",\"style\":{\"display\":\"block\",\"padding\":\"1.25rem\",\"backgroundColor\":\"rgba(255, 255, 255, 0.03)\",\"border\":\"1px solid rgba(255, 255, 255, 0.06)\",\"borderRadius\":\"1.25rem\",\"text