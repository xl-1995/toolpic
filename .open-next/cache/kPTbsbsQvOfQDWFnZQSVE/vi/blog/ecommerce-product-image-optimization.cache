 recommend 1200 x 1200 or 1500 x 1500 pixels for square product images.\\\"}]]}],[\\\"$\\\",\\\"section\\\",\\\"2\\\",{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\\\",\\\"children\\\":\\\"Image SEO for E-commerce\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\\\",\\\"children\\\":\\\"Search engines cannot see your images, but they read the text you associate with them. jpg provide no useful information.\\\"}]]}],\\\"$L1e\\\"]}],\\\"$L1f\\\"]}]]\\n\"])</script><script>self.__next_f.push([1,\"1e:[\\\"$\\\",\\\"section\\\",\\\"3\\\",{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\\\",\\\"children\\\":\\\"Optimizing Product Images with ToolPic\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\\\",\\\"children\\\":\\\"Start by cropping your product photos to a consistent aspect ratio using ToolPic's Image Crop tool. Square crops (1:1) work best for most e-commerce platforms and ensure a clean, uniform grid layout in category pages. Crop tightly around the product to maximize the visual impact at smaller display sizes.\\\"}]]}]\\n1f:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-16 pt-10 border-t border-[var(--color-border)]\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-xl font-bold mb-6 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"i\\\",null,{\\\"className\\\":\\\"fas fa-wrench text-[var(--color-purple)]\\\"}],\\\"Công cụ liên quan\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid grid-cols-1 sm:grid-cols-2 gap-4\\\",\\\"children\\\":[\\\"$L20\\\",\\\"$L21\\\"]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"22:I[7088,[\\\"619\\\",\\\"static/chunks/619-ba102abea3e