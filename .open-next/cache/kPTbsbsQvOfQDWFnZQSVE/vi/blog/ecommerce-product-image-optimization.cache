:\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"ToolPic\\\",\\\"item\\\":\\\"https://toolpic.me/vi\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Blog\\\",\\\"item\\\":\\\"https://toolpic.me/vi/blog\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Hướng Dẫn Tối Ưu Hóa Ảnh Sản Phẩm Cho Thương Mại Điện Tử\\\",\\\"item\\\":\\\"https://toolpic.me/vi/blog/ecommerce-product-image-optimization\\\"}]}\"}}],[\"$\",\"div\",null,{\"className\":\"background-grid\"}],[\"$\",\"article\",null,{\"className\":\"max-w-[800px] mx-auto px-4 sm:px-6 lg:px-8 pt-16 sm:pt-24 pb-24\",\"children\":[\"$L1d\",[\"$\",\"header\",null,{\"className\":\"mb-12\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight tracking-tight mb-4 gradient-text\",\"children\":\"Hướng Dẫn Tối Ưu Hóa Ảnh Sản Phẩm Cho Thương Mại Điện Tử\"}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 text-sm text-[var(--color-text-muted)]\",\"children\":[[\"$\",\"span\",null,{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"i\",null,{\"className\":\"fas fa-calendar-alt text-xs\"}],\"17 tháng 3, 2026\"]}],[\"$\",\"span\",null,{\"className\":\"w-1 h-1 rounded-full bg-[var(--color-text-muted)]\"}],[\"$\",\"span\",null,{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"i\",null,{\"className\":\"fas fa-clock text-xs\"}],\"Đọc 6 phút\"]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mb-12 rounded-2xl overflow-hidden\",\"children\":[\"$\",\"img\",null,{\"src\":\"/blog/ecommerce-images-hero.jpg\",\"alt\":\"Hướng Dẫn Tối Ưu Hóa Ảnh Sản Phẩm Cho Thương Mại Điện Tử\",\"className\":\"w-full h-auto\"}]}],[\"$\",\"div\",null,{\"className\":\"space-y-10\",\"children\":[[\"$\",\"section\",\"0\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\",\"children\":\"Why Product Images Drive Sales\"}],[\"$\",\"div\",null,{\"className\":\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\",\"children\":\"In e-commerce, product images are your most powerful sales tool. Studies show that 75% of online shoppers rely on product photos when making purchase decisions. High-quality images build trust, reduce return rates, and directly increase conversion rates.\"}]]}],[\"$\",\"section\",\"1\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\",\"children\":\"Recommended Sizes and Formats\"}],[\"$\",\"div\",null,{\"className\":\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\",\"children\":\"For main product images, use dimensions between 1000 and 2000 pixels on the longest side. This provides enough resolution for zoom functionality without being excessively large. Most e-commerce platforms recommend 1200 x 1200 or 1500 x 1500 pixels for square product images.\"}]]}],[\"$\",\"section\",\"2\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\",\"children\":\"Image SEO for E-commerce\"}],[\"$\",\"div\",null,{\"className\":\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\",\"children\":\"Search engines cannot see your images, but they read the text you associate with them. jpg provide no useful information.\"}]]}],\"$L1e\"]}],\"$L1f\"]}]]\n1e:[\"$\",\"section\",\"3\",{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl sm:text-3xl font-bold mb-4 text-[var(--color-text)]\",\"children\":\"Optimizing Product Images with ToolPic\"}],[\"$\",\"div\",null,{\"className\":\"text-[var(--color-text-muted)] leading-[1.8] text-[1.05rem] whitespace-pre-line\",\"children\":\"Start by cropping your product photos to a consistent aspect ratio using ToolPic's Image Crop tool. Square crops (1:1) work best for most e-commerce platforms and ensure a clean, uniform grid layout in category pages. Crop tightly around the product to maximize the visual impact at smaller display sizes.\"}]]}]\n1f:[\"$\",\"div\",null,{\"className\":\"mt-16 pt-10 border-t border-[var(--color-border)]\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-xl font-bold mb-6 flex items-center gap-2\",\"children\":[[\"$\",\"i\",null,{\"className\":\"fas fa-wrench text-[var(--color-purple)]\"}],\"Công cụ liên quan\"]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 sm:grid-cols-2 gap-4\",\"children\":[\"$L20\",\"$L21\"]}]]}]\n22:I[7088,[\"619\",\"static/chunks/619-ba102abea3e3d0e4.js\",\"707\",\"static/chunks/707-58f78ad8b0d495a8.js\",\"414\",\"static/chunks/app/%5Blocale%5D/blog/%5Bslug%5D/page-2e29ca0deafe7a99.js\"],\"default\"]\n1d:[\"$\",\"$L22\",null,{\"ref\":\"$undefined\",\"href\":\"/vi/blog\",\"locale\":\"$undefined\",\"localeCookie\":{\"name\":\"NEXT_LOCALE\",\"sameSite\":\"lax\"},\"className\":\"inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300 mb-8\",\"children\":[[\"$\",\"i\",null,{\"className\":\"fas fa-arrow-left text-xs\"}],\"Blog\"]}]\n20:[\"$\",\"$L22\",\"image-compressor\",{\"ref\":\"$undefined\",\"href\":\"/vi/tools/nen-anh\",\"locale\":\"$undefined\",\"localeCookie\":\"$1d:props:localeCookie\",\"className\":\"glass-card p-5 block hover:border-[var(--color-border-hover)] transition-all duration-300 group\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-9 h-9 rounded-full bg-gradient-to-br from-[var(--color-purple)]/10 to-[var(--color-blue)]/10 flex items-center justify-center\",\"children\":[\"$\",\"i\",null,{\"className\":\"fas fa-compress text-sm text-[var(--color-text)]\"}]}],[\"$\",\"h4\",null,{\"className\":