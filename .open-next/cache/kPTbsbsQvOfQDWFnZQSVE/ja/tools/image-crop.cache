\"}]\n29:[\"$\",\"$L2c\",null,{\"ref\":\"$undefined\",\"href\":\"/ja/tools/video-convert\",\"locale\":\"$undefined\",\"localeCookie\":\"$23:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"動画形式変換\"}]\n2a:[\"$\",\"$L2c\",null,{\"ref\":\"$undefined\",\"href\":\"/ja/tools/video-to-gif\",\"locale\":\"$undefined\",\"localeCookie\":\"$23:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"動画からGIF変換\"}]\n2b:[\"$\",\"$L2c\",null,{\"ref\":\"$undefined\",\"href\":\"/ja/blog\",\"locale\":\"$undefined\",\"localeCookie\":\"$23:props:localeCookie\",\"className\":\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\",\"children\":\"ブログ\"}]\n18:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n14:null\n2d:I[622,[],\"IconMark\"]\n16:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"無料オンライン画像切り抜き・リサイズツール | ToolPic\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"無料で画像をオンラインで切り抜き・リサイズ。SNS用プリセットサイズ対応。アップロード不要。\"}],[\"$\",\"link\",\"2\",{\"rel\":\"manifest\",\"href\":\"/manifest.json\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://toolpic.me/ja/tools/image-crop\"}],[\"$\",\"link\",\"4\",{\"rel\":\"alternate\",\"hrefLang\":\"en\",\"href\":\"https://toolpic.me/en/tools/image-crop\"}],[\"$\",\"link\",\"5\",{\"rel\":\"alternate\",\"hrefLang\":\"zh\",\"href\":\"https://toolpic.me/zh/tools/image-crop\"}],[\"$\",\"link\",\"6\",{\"rel\":\"alternate\",\"hrefLang\":\"ja\",\"href\":\"https://toolpic.me/ja/tools/image-crop\"}],[\"$\",\"link\",\"7\",{\"rel\":\"alternate\",\"hrefLang\":\"ko\",\"href\":\"https://toolpic.me/ko/tools/image-crop\"}],[\"$\",\"link\",\"8\",{\"rel\":\"alternate\",\"hrefLang\"