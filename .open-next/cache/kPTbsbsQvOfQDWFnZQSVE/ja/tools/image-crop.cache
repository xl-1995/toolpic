\"href\":\"https://toolpic.me/en/tools/image-crop\"}],[\"$\",\"meta\",\"25\",{\"property\":\"og:title\",\"content\":\"無料オンライン画像切り抜き・リサイズツール | ToolPic\"}],[\"$\",\"meta\",\"26\",{\"property\":\"og:description\",\"content\":\"無料で画像をオンラインで切り抜き・リサイズ。SNS用プリセットサイズ対応。アップロード不要。\"}],[\"$\",\"meta\",\"27\",{\"property\":\"og:url\",\"content\":\"https://toolpic.me/ja/tools/image-crop\"}],[\"$\",\"meta\",\"28\",{\"property\":\"og:site_name\",\"content\":\"ToolPic\"}],[\"$\",\"meta\",\"29\",{\"property\":\"og:locale\",\"content\":\"ja\"}],[\"$\",\"meta\",\"30\",{\"property\":\"og:image\",\"content\":\"https://toolpic.me/og-image.jpg\"}],[\"$\",\"meta\",\"31\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"32\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"33\",{\"property\":\"og:image:alt\",\"content\":\"ToolPic - Free Online Image & Video Tools\"}],[\"$\",\"meta\",\"34\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"35\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"36\",{\"name\":\"twitter:title\",\"content\":\"無料オンライン画像切り抜き・リサイズツール | ToolPic\"}],[\"$\",\"meta\",\"37\",{\"name\":\"twitter:description\",\"content\":\"無料で画像をオンラインで切り抜き・リサイズ。SNS用プリセットサイズ対応。アップロード不要。\"}],[\"$\",\"meta\",\"38\",{\"name\":\"twitter:image\",\"content\":\"https://toolpic.me/og-image.jpg\"}],[\"$\",\"link\",\"39\",{\"rel\":\"icon\",\"href\":\"/favicon.svg\",\"type\":\"image/svg+xml\"}],[\"$\",\"link\",\"40\",{\"rel\":\"icon\",\"href\":\"/icon-512.png\",\"type\":\"image/png\",\"sizes\":\"512x512\"}],[\"$\",\"link\",\"41\",{\"rel\":\"apple-touch-icon\",\"href\":\"/apple-touch-icon.png\"}],[\"$\",\"$L2d\",\"42\",{}]],\"error\":null,\"digest\":\"$undefined\"}\n1b:\"$16:metadata\"\n"}