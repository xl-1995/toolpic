p\"/><meta property=\"og:title\" content=\"無料オンライン画像切り抜き・リサイズツール | ToolPic\"/><meta property=\"og:description\" content=\"無料で画像をオンラインで切り抜き・リサイズ。SNS用プリセットサイズ対応。アップロード不要。\"/><meta property=\"og:url\" content=\"https://toolpic.me/ja/tools/image-crop\"/><meta property=\"og:site_name\" content=\"ToolPic\"/><meta property=\"og:locale\" content=\"ja\"/><meta property=\"og:image\" content=\"https://toolpic.me/og-image.jpg\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"ToolPic - Free Online Image &amp; Video Tools\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"無料オンライン画像切り抜き・リサイズツール | ToolPic\"/><meta name=\"twitter:description\" content=\"無料で画像をオンラインで切り抜き・リサイズ。SNS用プリセットサイズ対応。アップロード不要。\"/><meta name=\"twitter:image\" content=\"https://toolpic.me/og-image.jpg\"/><link rel=\"icon\" href=\"/favicon.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/icon-512.png\" type=\"image/png\" sizes=\"512x512\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\"/><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/><link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-screen flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"sticky top-0 z-50 transition-all duration-300 \"><div class=\"max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex items-center justify-between h-16\"><a class=\"flex items-center gap-3\" href=\"/ja\"><span class=\"w-9 h-9 rounded-lg bg-gradient-to-br from-[var(--color-purple)] to-[var(--color-blue)] flex items-center justify-center\"><i class=\"fas fa-wand-magic-sparkles text-white text-base\"></i></span><span class=\"text-2xl font-bold tracking-tight\">ToolPic</span></a><nav class=\"hidden md:flex items-center gap-8\"><a class=\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] font-medium transition-colors duration-300\" href=\"/ja\">ホーム</a><a class=\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] font-medium transition-colors duration-300\" href=\"/ja#image-tools\">画像ツール</a><a class=\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] font-medium transition-colors duration-300\" href=\"/ja#video-tools\">動画ツール</a><a class=\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] font-medium transition-colors duration-300\" href=\"/ja/blog\">ブログ</a></nav><div class=\"flex items-center gap-4\"><div class=\"relative flex items-center\"><i class=\"fas fa-globe text-[var(--color-text-muted)] text-lg pointer-events-none absolute left-0\"></i><select class=\"appearance-none bg-transparent text-[var(--color-text-muted)] hover:text-[var(--color-text)] cursor-pointer pl-6 pr-4 py-1 text-sm font-medium border-none outline-none transition-colors duration-300\" aria-label=\"Change language\"><option value=\"en\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">English</option><option value=\"zh\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">中文</option><option value=\"ja\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\" selected=\"\">日本語</option><option value=\"ko\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">한국어</option><option value=\"es\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Español</option><option value=\"fr\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Français</option><option value=\"de\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Deutsch</option><option value=\"pt\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Português</option><option value=\"ru\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Русский</option><option value=\"ar\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">العربية</option><option value=\"hi\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">हिन्दी</option><option value=\"it\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Italiano</option><option value=\"tr\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Türkçe</option><option value=\"vi\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Tiếng Việt</option><option value=\"th\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">ไทย</option><option value=\"id\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Bahasa</option><option value=\"nl\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Nederlands</option><option value=\"pl\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Polski</option><option value=\"uk\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Українська</option><option value=\"ms\" class=\"bg-[var(--color-bg)] text-[var(--color-text)]\">Melayu</option></select><i class=\"fas fa-chevron-down text-[var(--color-text-muted)] text-xs pointer-events-none\"></i></div><button class=\"md:hidden text-[var(--color-text-muted)] hover:text-[var(--color-text)] text-xl transition-colors\" aria-label=\"Toggle menu\"><i class=\"fas fa-bars\"></i></button></div></div></div></header><main class=\"flex-1\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebApplication\",\"name\":\"無料オンライン画像切り抜き・リサイズツール | ToolPic\",\"description\":\"無料で画像をオンラインで切り抜き・リサイズ。SNS用プリセットサイズ対応。アップロード不要。\",\"url\":\"https://toolpic.me/ja/tools/image-crop\",\"applicationCategory\":\"MultimediaApplication\",\"operatingSystem\":\"Any\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"どのSNSサイズに対応していますか？\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Instagramの投稿（1080x1080）、Instagramストーリー（1080x1920）、Facebookカバー（820x312）、Twitterヘッダー（1500x500）、YouTubeサムネイル（1280x720）などのプリセットを用意しています。\"}},{\"@type\":\"Question\",\"name\":\"切り抜かずにリサイズだけできますか？\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"はい。カスタムの幅と高さを設定して、画像を比例的にまたは正確な寸法にリサイズできます。画像のどの部分も切り取られません。\"}},{\"@type\":\"Question\",\"name\":\"切り抜きで画質は下がりますか？\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"いいえ。切り抜きは選択範囲外の部分を除去するだけです。残りの部分は元の画質を完全に維持します。\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"ToolPic\",\"item\":\"https://toolpic.me/ja\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"無料オンライン画像切り抜き・リサイズツール | ToolPic\",\"item\":\"https://toolpic.me/ja/tools/image-crop\"}]}</script><div class=\"max-w-[900px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20\"><div class=\"text-center mb-12\"><h1 class=\"text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4 gradient-text tracking-tight\">オンライン画像切り抜き・リサイズ - 無料</h1><p class=\"text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed\">SNS用プリセットサイズで画像を切り抜き・リサイズ。</p></div><div class=\"glass-card p-6 sm:p-8\"><div class=\"drop-zone p-16 text-center cursor-pointer \"><input type=\"file\" accept=\"image/*\" class=\"hidden\"/><div class=\"flex flex-col items-center gap-5\"><div class=\"text-5xl text-[var(--color-purple)]\"><i class=\"fas fa-cloud-arrow-up\"></i></div><div><p class=\"text-lg font-semibold\">ファイルをアップロード</p><p class=\"text-[var(--color-text-muted)] mt-1\">またはここにドラッグ＆ドロップ</p></div><p class=\"text-sm text-[var(--color-text-dim)]\">最大ファイルサイズ：50MB</p></div></div></div><div class=\"mt-8 text-center\"><p class=\"text-sm text-[var(--color-text-muted)] flex items-center justify-center gap-3\"><i class=\"fas fa-shield-halved text-[var(--color-success)]\"></i>ファイルはブラウザ内でローカル処理されます。サーバーにアップロードされることはありません。</p></div></div><div class=\"max-w-[900px] mx-auto px-4 sm:px-6 lg:px-8 py-16\"><section class=\"mb-16\"><h2 class=\"text-2xl font-bold mb-8 gradient-text\">画像を切り抜き・リサイズする方法</h2><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\"><div class=\"glass-card p-6 text-center\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)] to-[var(--color-blue)] flex items-center justify-center mx-auto mb-4 text-white font-bold\">1</div><h3 class=\"font-semibold mb-2\">画像をアップロード</h3><p class=\"text-sm text-[var(--color-text-muted)]\">ドラッグ＆ドロップまたはクリックして、切り抜きやリサイズしたい画像を選択します。</p></div><div class=\"glass-card p-6 text-center\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)] to-[var(--color-blue)] flex items-center justify-center mx-auto mb-4 text-white font-bold\">2</div><h3 class=\"font-semibold mb-2\">切り抜き範囲を調整</h3><p class=\"text-sm text-[var(--color-text-muted)]\">切り抜きハンドルをドラッグするか、SNSプラットフォーム用のプリセット比率を選択します。</p></div><div class=\"glass-card p-6 text-center\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)] to-[var(--color-blue)] flex items-center justify-center mx-auto mb-4 text-white font-bold\">3</div><h3 class=\"font-semibold mb-2\">結果をダウンロード</h3><p class=\"text-sm text-[var(--color-text-muted)]\">切り抜きを適用して、最適なサイズの画像をダウンロードします。</p></div></div></section><section class=\"mb-16\"><h2 class=\"text-2xl font-bold mb-8 gradient-text\">主な機能</h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"glass-card p-6\"><h3 class=\"font-semibold mb-2\">SNSプリセット</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed\">Instagram、Facebook、Twitter、YouTubeサムネイルなどのワンクリックプリセットを用意。</p></div><div class=\"glass-card p-6\"><h3 class=\"font-semibold mb-2\">カスタムアスペクト比</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed\">任意の幅と高さを設定、またはアスペクト比をロックして精密な切り抜きが可能。</p></div><div class=\"glass-card p-6\"><h3 class=\"font-semibold mb-2\">ビジュアル切り抜きエディタ</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed\">直感的なドラッグ操作で、保持したい領域を正確に選択できます。</p></div><div class=\"glass-card p-6\"><h3 class=\"font-semibold mb-2\">画質劣化なし</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed\">再圧縮なしで切り抜き・リサイズ。元の画質が完全に維持されます。</p></div></div></section><section><h2 class=\"text-2xl font-bold mb-8 gradient-text\">よくある質問</h2><div class=\"space-y-4\"><details class=\"glass-card p-6 group\"><summary class=\"font-semibold cursor-pointer list-none flex items-center justify-between\">どのSNSサイズに対応していますか？<i class=\"fas fa-chevron-down text-sm text-[var(--color-text-muted)] group-open:rotate-180 transition-transform\"></i></summary><p class=\"text-[var(--color-text-muted)] mt-3 leading-relaxed\">Instagramの投稿（1080x1080）、Instagramストーリー（1080x1920）、Facebookカバー（820x312）、Twitterヘッダー（1500x500）、YouTubeサムネイル（1280x720）などのプリセットを用意しています。</p></details><details class=\"glass-card p-6 group\"><summary class=\"font-semibold cursor-pointer list-none flex items-center justify-between\">切り抜かずにリサイズだけできますか？<i class=\"fas fa-chevron-down text-sm text-[var(--color-text-muted)] group-open:rotate-180 transition-transform\"></i></summary><p class=\"text-[var(--color-text-muted)] mt-3 leading-relaxed\">はい。カスタムの幅と高さを設定して、画像を比例的にまたは正確な寸法にリサイズできます。画像のどの部分も切り取られません。</p></details><details class=\"glass-card p-6 group\"><summary class=\"font-semibold cursor-pointer list-none flex items-center justify-between\">切り抜きで画質は下がりますか？<i class=\"fas fa-chevron-down text-sm text-[var(--color-text-muted)] group-open:rotate-180 transition-transform\"></i></summary><p class=\"text-[var(--color-text-muted)] mt-3 leading-relaxed\">いいえ。切り抜きは選択範囲外の部分を除去するだけです。残りの部分は元の画質を完全に維持します。</p></details></div></section></div><div class=\"max-w-[900px] mx-auto px-4 sm:px-6 lg:px-8 pb-16\"><h2 class=\"text-2xl font-bold mb-8 gradient-text\">おすすめツール</h2><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4\"><a class=\"tool-card glass-card p-6 block\" href=\"/ja/tools/image-compressor\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)]/10 to-[var(--color-blue)]/10 flex items-center justify-center mb-4\"><i class=\"fas fa-compress text-lg text-[var(--color-text)]\"></i></div><h3 class=\"text-base font-semibold mb-1\">画像圧縮</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-2\">JPEG、PNG、WebP画像を最大80%スマート圧縮。</p></a><a class=\"tool-card glass-card p-6 block\" href=\"/ja/tools/image-converter\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)]/10 to-[var(--color-blue)]/10 flex items-center justify-center mb-4\"><i class=\"fas fa-exchange-alt text-lg text-[var(--color-text)]\"></i></div><h3 class=\"text-base font-semibold mb-1\">画像形式変換</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-2\">JPG、PNG、WebP、AVIF、BMP形式間で自由に変換。</p></a><a class=\"tool-card glass-card p-6 block\" href=\"/ja/tools/image-watermark\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)]/10 to-[var(--color-blue)]/10 flex items-center justify-center mb-4\"><i class=\"fas fa-stamp text-lg text-[var(--color-text)]\"></i></div><h3 class=\"text-base font-semibold mb-1\">ウォーターマーク追加</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-2\">写真にテキストや画像のウォーターマークを一括追加。</p></a><a class=\"tool-card glass-card p-6 block\" href=\"/ja/tools/remove-background\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)]/10 to-[var(--color-blue)]/10 flex items-center justify-center mb-4\"><i class=\"fas fa-eraser text-lg text-[var(--color-text)]\"></i></div><h3 class=\"text-base font-semibold mb-1\">AI背景除去</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-2\">AI搭載の背景除去。透過PNGを数秒で生成。</p></a><a class=\"tool-card glass-card p-6 block\" href=\"/ja/tools/image-merge\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)]/10 to-[var(--color-blue)]/10 flex items-center justify-center mb-4\"><i class=\"fas fa-th-large text-lg text-[var(--color-text)]\"></i></div><h3 class=\"text-base font-semibold mb-1\">画像結合</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-2\">複数画像を結合。コラージュやロング画像を作成。</p></a><a class=\"tool-card glass-card p-6 block\" href=\"/ja/tools/video-compressor\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-purple)]/10 to-[var(--color-blue)]/10 flex items-center justify-center mb-4\"><i class=\"fas fa-file-video text-lg text-[var(--color-text)]\"></i></div><h3 class=\"text-base font-semibold mb-1\">動画圧縮</h3><p class=\"text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-2\">解像度とビットレートを調整して動画を圧縮。</p></a></div></div><!--$--><!--/$--></main><footer class=\"bg-[#040405] border-t border-[var(--color-border)] mt-20\"><div class=\"max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8\"><div class=\"grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10 mb-12\"><div><div class=\"flex items-center gap-3 mb-4\"><span class=\"w-9 h-9 rounded-lg bg-gradient-to-br from-[var(--color-purple)] to-[var(--color-blue)] flex items-center justify-center\"><i class=\"fas fa-wand-magic-sparkles text-white text-base\"></i></span><span class=\"text-2xl font-bold tracking-tight\">ToolPic</span></div><p class=\"text-[var(--color-text-muted)] max-w-[300px] leading-relaxed\">無料オンライン画像・動画ツール。100%ブラウザ処理、ファイルはデバイスから離れません。</p></div><div><h3 class=\"text-lg font-semibold mb-4\">ツール</h3><ul class=\"space-y-3\"><li><a class=\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\" href=\"/ja/tools/image-compressor\">画像圧縮</a></li><li><a class=\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\" href=\"/ja/tools/image-converter\">画像形式変換</a></li><li><a class=\"text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300\" href=\"/ja/tools/image-crop\">画像切り抜き・リサイズ</a></li><li><a class=\"text-[var(--color-text-muted)] 